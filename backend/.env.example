# =============================================================================
# Herbalife Distributor SaaS Platform - Environment Variables
# Copyright © 2026 WEBLIFETECH (Jonnathan Peña). All Rights Reserved.
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key
API_BASE_URL=http://localhost:5000

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# --- Database (MySQL) ---
# Leave empty to use SQLite fallback in development
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
# Or set a full DATABASE_URL:
# DATABASE_URL=mysql+pymysql://user:password@host:3306/enpi_ai

# --- Pinecone (Vector DB) ---
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=enpi-ai-rag

# --- LLM Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-5-nano

# --- Google APIs (Calendar, Gmail, OAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# Base64-encoded credentials JSON or path to file:
# GOOGLE_CREDENTIALS_JSON=

# --- SMTP (Email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# --- WhatsApp Service ---
WHATSAPP_API_URL=http://localhost:3001
WHATSAPP_API_SECRET=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
